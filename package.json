{
  "name": "gatecode-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute gatecode-db --local --file=src/db/schema.sql",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "cli:build": "cd cli && npm run build",
    "cli:publish": "cd cli && npm publish --access public"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240614.0",
    "bun-types": "^1.1.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.80.0"
  }
}
